
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a customer's personal information.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "registrationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "email", "registrationDate"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "An individual item in the catalog.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "price": { "type": "number" },
        "stockQuantity": { "type": "number" },
        "category": { "type": "string" }
      },
      "required": ["id", "name", "price", "stockQuantity"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "A stock request from a retailer.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "string" },
        "quantity": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled"] },
        "storeName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "total", "status", "phoneNumber", "deliveryAddress"]
    },
    "Store": {
      "title": "Store",
      "type": "object",
      "description": "A retailer's branch details.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "managerName": { "type": "string" },
        "location": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["pending", "active", "rejected"] }
      },
      "required": ["id", "name", "status"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Global product catalog."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Consolidated store orders."
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Retailer registration records."
    }
  }
}
