
{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "type": "object",
      "description": "Represents a customer's personal information.",
      "properties": {
        "id": { "type": "string" },
        "username": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "registrationDate": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "username", "email", "registrationDate"]
    },
    "Product": {
      "title": "Product",
      "type": "object",
      "description": "An individual item in the catalog.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "sku": { "type": "string" },
        "price": { "type": "number", "description": "The actual offer price the retailer pays." },
        "mrp": { "type": "number", "description": "The maximum retail price for comparison." },
        "stockQuantity": { "type": "number" },
        "category": { "type": "string" },
        "imageUrl": { "type": "string", "description": "Public URL for the product identity image." }
      },
      "required": ["id", "name", "price", "stockQuantity"]
    },
    "Order": {
      "title": "Order",
      "type": "object",
      "description": "A stock request or damage return from a retailer.",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "items": { "type": "string" },
        "quantity": { "type": "number" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "processing", "shipped", "delivered", "cancelled", "return_pending", "returned"] },
        "paymentMethod": { "type": "string", "enum": ["cash", "after_delivery"] },
        "storeName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phoneNumber": { "type": "string" },
        "deliveryAddress": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "total", "status", "phoneNumber", "deliveryAddress", "paymentMethod"]
    },
    "Store": {
      "title": "Store",
      "type": "object",
      "description": "A retailer's branch details.",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "managerName": { "type": "string" },
        "location": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "status": { "type": "string", "enum": ["pending", "active", "rejected"] }
      },
      "required": ["id", "name", "status"]
    },
    "AdminRole": {
      "title": "AdminRole",
      "type": "object",
      "description": "Administrative authority record.",
      "properties": {
        "uid": { "type": "string" },
        "role": { "type": "string", "enum": ["master", "regional"] }
      },
      "required": ["uid", "role"]
    }
  },
  "auth": {
    "providers": ["password", "anonymous"]
  },
  "firestore": {
    "indexes": [
      {
        "collectionGroup": "orders",
        "queryScope": "COLLECTION",
        "fields": [
          { "fieldPath": "userId", "order": "ASCENDING" },
          { "fieldPath": "createdAt", "order": "DESCENDING" }
        ]
      }
    ],
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles."
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Global product catalog."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Consolidated store orders and damage reports."
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Retailer registration records."
    },
    "/roles_admin/{uid}": {
      "schema": "AdminRole",
      "description": "Registry of authorized administrative identities."
    }
  }
}
