
{
  "entities": {
    "Store": {
      "title": "Store",
      "description": "A retail store location in the network.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "location": { "type": "string" },
        "managerId": { "type": "string" },
        "status": { 
          "type": "string", 
          "enum": ["pending", "active", "rejected"] 
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "managerId", "status"]
    },
    "Product": {
      "title": "Product",
      "description": "An inventory item available for ordering.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "sku": { "type": "string" },
        "mrp": { "type": "number" },
        "currentStock": { "type": "number" },
        "unit": { "type": "string" }
      },
      "required": ["name", "sku", "mrp", "currentStock"]
    },
    "Order": {
      "title": "Order",
      "description": "A stock request from a store.",
      "type": "object",
      "properties": {
        "storeId": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "quantity": { "type": "number" }
            }
          }
        },
        "totalAmount": { "type": "number" },
        "status": {
          "type": "string",
          "enum": ["pending", "processing", "shipped", "delivered", "cancelled"]
        },
        "priority": { "type": "string", "enum": ["low", "normal", "high"] },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": ["password", "google"]
  },
  "firestore": {
    "/stores/{storeId}": {
      "schema": "#/entities/Store",
      "description": "Store profiles and registration status."
    },
    "/inventory/{productId}": {
      "schema": "#/entities/Product",
      "description": "Global inventory and pricing master data."
    },
    "/orders/{orderId}": {
      "schema": "#/entities/Order",
      "description": "Consolidated order tracking for all stores."
    }
  }
}
