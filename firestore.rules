rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Prototype override: Grant admin access to specific UIDs
      return isSignedIn() && (
        request.auth.uid == "AEGmDwRin2c5sDZdx1Jhk87yF9L2" ||
        request.auth.uid == "cKRTD1vPTOfID6XADH31VVpGYAU2" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User Profiles
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Global Product Catalog: Publicly readable for authenticated users
    match /products/{productId} {
      allow read: if isSignedIn(); 
      allow write: if isAdmin();
    }

    // Orders: Admins see all; Users see their own
    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Store Registration
    match /stores/{storeId} {
      allow read: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isSignedIn(); 
      allow update, delete: if isAdmin();
    }

    // Admin Roles
    match /roles_admin/{adminUid} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}