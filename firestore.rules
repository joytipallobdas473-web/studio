rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for regional security protocols
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.uid == 'j96izCkggNcL002AHiJjzGb18Bf2' ||
        (request.auth.token.email != null && request.auth.token.email.lower().contains('admin'))
      );
    }

    // Products: Any authenticated node can read. Only admins can provision SKUs.
    match /products/{productId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Stores: Users can access their own node. Admins have global visibility.
    match /stores/{storeId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == storeId);
    }

    // Orders: Users can read/write their own packets. Admins monitor global traffic.
    match /orders/{orderId} {
      allow read: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.userId);
    }

    // UserProfiles: Individual identity protection.
    match /users/{userId} {
      allow read, write: if isAdmin() || (isSignedIn() && request.auth.uid == userId);
    }
    
    // Global fallback for restricted paths
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}