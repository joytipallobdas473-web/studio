rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * CORE SECURITY PROTOCOL
     * 
     * Admins (Explicit UIDs + roles_admin registry) have full access.
     * Retailers have ownership-based access.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      // Explicit override for the developer/owner UIDs to ensure immediate access
      return isSignedIn() && (
        request.auth.uid == "AEGmDwRin2c5sDZdx1Jhk87yF9L2" ||
        request.auth.uid == "cKRTD1vPTOfID6XADH31VVpGYAU2" ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Collection Rules ---

    // User Profiles: Private to the user and Admins
    match /users/{userId} {
      allow read, write: if isOwner(userId) || isAdmin();
    }

    // Global Product Catalog: Publicly readable, Admin writeable
    match /products/{productId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Consolidated Orders: Admins see all; Users see their own
    match /orders/{orderId} {
      allow get, list: if isAdmin() || (isSignedIn() && (resource == null || resource.data.userId == request.auth.uid));
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow delete: if isAdmin();
    }

    // Store Registration: Anyone can apply; Admins manage
    match /stores/{storeId} {
      allow get, list: if isAdmin();
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    // Administrative Roles Registry
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list, write: if isAdmin();
    }
  }
}