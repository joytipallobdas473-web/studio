rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * DOCUMENTATION
     *
     * Core Philosophy: 
     * - Admins (defined in roles_admin) have global visibility.
     * - Retailers manage their own data via identity-based ownership.
     */

    // --- Helper Functions ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }

    // --- Collection Rules ---

    // User Profiles
    match /users/{userId} {
      allow get, list: if isOwner(userId);
      allow create, update: if isOwner(userId);
    }

    // Product Catalog
    match /products/{productId} {
      allow read: if true; 
      allow write: if isAdmin();
    }

    // Consolidated Orders
    match /orders/{orderId} {
      // Admins see all. Users see their own.
      allow list, get: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      // Users can create orders.
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      
      // Admin handles status updates. Users can update their own pending orders.
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      
      allow delete: if isAdmin();
    }

    // Store Registration Queue
    match /stores/{storeId} {
      allow list, get: if isAdmin();
      allow create: if true; 
      allow update, delete: if isAdmin();
    }

    // Administrative Roles
    match /roles_admin/{adminUid} {
      allow get: if isSignedIn();
      allow list: if false;
    }
  }
}